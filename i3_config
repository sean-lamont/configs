# i3 config for ML Engineering & Research Workflow
# Home Row Vim Navigation (h, j, k, l)
set $mod Mod4

# --- Quality of Life & Speeds ---
# Fast keyboard repeat rate (crucial for Vim/Tmux scrolling speed)
exec --no-startup-id xset r rate 250 50

# Workspace toggle (Pressing $mod+2 while on workspace 2 sends you to your previous workspace)
workspace_auto_back_and_forth yes

# --- Visuals & Fonts ---
# Using the Nerd Font installed via setup.sh for proper icon rendering
font pango:JetBrainsMono Nerd Font 10

# --- Core Executables ---
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id nm-applet

# Ensures terminal transparency (requires picom installed via setup.sh)
exec_always --no-startup-id picom -b

# --- Navigation (Direct Vim-style: h, j, k, l) ---
# Overwriting defaults directly to avoid unbindsym errors

# Change Focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Move Focused Window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# --- Window Management ---
# Launches your zsh -> tmux terminal pipeline
bindsym $mod+Return exec i3-sensible-terminal

# Kill focused window
bindsym $mod+Shift+q kill

# Application Launcher
# bindsym $mod+d exec --no-startup-id dmenu_run
# Use Rofi instead of dmenu for a "GNOME-style" search
# bindsym $mod+space exec --no-startup-id /home/linuxbrew/.linuxbrew/bin/rofi -show drun -show-icons


# --- Layout Control ---
# Vertical/Horizontal splits (mirrors tmux 'v' and 's' bindings)
bindsym $mod+v split h
bindsym $mod+s split v
bindsym $mod+f fullscreen toggle

# Layout styles
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# --- Workspaces ---
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4

# --- System ---
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'Exit i3?' -B 'Yes' 'i3-msg exit'"

# Quick fix to reload custom keyboard maps if they drop out
bindsym $mod+Shift+m exec --no-startup-id xmodmap ~/.Xmodmap

# --- Clean Resize Mode (Vim-style) ---
mode "resize" {
    bindsym h resize shrink width 10 px or 10 ppt
    bindsym j resize grow height 10 px or 10 ppt
    bindsym k resize shrink height 10 px or 10 ppt
    bindsym l resize grow width 10 px or 10 ppt

    # Return to normal mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

bar {
    status_command i3status
    colors {
        background #282a36
        statusline #f8f8f2
        separator  #44475a
        # Dracula-inspired workspace colors
        focused_workspace  #bd93f9 #bd93f9 #282a36
        active_workspace   #44475a #44475a #f8f8f2
        inactive_workspace #282a36 #282a36 #f8f8f2
        urgent_workspace   #ff5555 #ff5555 #f8f8f2
    }
}

exec --no-startup-id i3-msg 'workspace 1; exec i3-sensible-terminal'
exec --no-startup-id i3-msg 'workspace 3; exec /usr/bin/firefox'
exec --no-startup-id i3-msg 'workspace 2; exec /home/sean/.local/share/JetBrains/Toolbox/scripts/pycharm'

# Cycle through windows on the current workspace
# bindsym $mod+Tab focus next
# bindsym $mod+Shift+Tab focus prev

# Map Alt+Tab to switch between all open windows
#bindsym Mod1+Tab exec /home/linuxbrew/.linuxbrew/bin/rofi -show window -show-icons

# Force Rofi to use a valid UTF-8 locale when launched via shortcut
bindsym $mod+space exec --no-startup-id env LC_ALL=en_US.UTF-8 rofi -show run
bindsym $mod+Tab exec --no-startup-id env LC_ALL=en_US.UTF-8 rofi -show window -show-icons


# Hide title bars but keep a 1px border
default_border pixel 2
default_floating_border pixel 2

# remap application key to window for certain keyboards.
exec --no-startup-id xmodmap ~/.Xmodmap

# 1. The Rule: Catch the specific gnome-terminal instance, float it, and hide it immediately
for_window [class="scratch-term"] floating enable, resize set 1000 600, move scratchpad, border pixel 2

# 2. The Command: Launch gnome-terminal with that exact custom class and start tmux
exec --no-startup-id gnome-terminal --class="scratch-term" -- tmux new-session -A -s scratch

# 3. The Toggle: Summon or hide the scratchpad
bindsym $mod+minus scratchpad show


# Locks screen with a custom image or color
bindsym $mod+Shift+x exec i3lock -c 000000

# Use Alt+Tab to switch to the last visited workspace
bindsym Mod1+Tab workspace back_and_forth

